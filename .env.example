# API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Runtime
MIN_MATCH_SCORE=5
MAX_DAILY_APPLICATIONS=10
DEFAULT_DRY_RUN=true
SCREENSHOT_DIR=.artifacts/screenshots
DEFAULT_REQUEST_FILE=examples/linkedin_request.json
START_MODE=command
START_SIGNAL_FILE=.artifacts/start.signal
START_SIGNAL_TIMEOUT_SECONDS=0

