# API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Runtime
MIN_MATCH_SCORE=60
MAX_DAILY_APPLICATIONS=10
DEFAULT_DRY_RUN=true
SCREENSHOT_DIR=.artifacts/screenshots

# LinkedIn (optional)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_STORAGE_STATE=.artifacts/linkedin-storage-state.json
LINKEDIN_HEADLESS=false
LINKEDIN_MANUAL_LOGIN_TIMEOUT_SECONDS=180
LINKEDIN_MAX_SEARCH_PAGES=3
