LINKEDIN_STORAGE_STATE=.artifacts/linkedin-storage-state.json
LINKEDIN_HEADLESS=false
LINKEDIN_MANUAL_LOGIN_TIMEOUT_SECONDS=180
LINKEDIN_MAX_SEARCH_PAGES=3
LINKEDIN_AI_NAVIGATION_ENABLED=true
